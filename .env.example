# LLM Configuration
# Set to 'local' for Ollama/HuggingFace or 'openai' for OpenAI API
LLM_PROVIDER=local

# OpenAI Settings (if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Embedding Settings
# Set to 'local' for Sentence-Transformers or 'openai' for OpenAI
EMBEDDING_PROVIDER=local

# Storage Paths
RAW_DATA_DIR=data/raw
VECTOR_STORE_DIR=data/vector_store
